# Artillery Load Testing Configuration
# Copy this to .env.load-test and configure for your environment

# Target URL for testing
# Local: http://localhost:3000
# Staging: https://your-staging.vercel.app
# Production: https://your-domain.com (use with caution!)
TEST_TARGET_URL=http://localhost:3000

# Authentication token for protected endpoints
# Get this from your auth system or create a test token
TEST_AUTH_TOKEN=your-test-auth-token-here

# Test workspace IDs (comma-separated)
# These should be real workspace IDs in your test environment
TEST_WORKSPACE_IDS=test-workspace-1,test-workspace-2,test-workspace-3

# Test document IDs for processing tests
# These should point to actual uploaded documents
TEST_DOCUMENT_SMALL_ID=doc-small-123
TEST_DOCUMENT_MEDIUM_ID=doc-medium-456
TEST_DOCUMENT_LARGE_ID=doc-large-789

# Optional: Rate limiting
# Slow down tests if hitting rate limits
TEST_ARRIVAL_RATE_MULTIPLIER=1.0

# Optional: Test duration multiplier
# Increase to run longer tests
TEST_DURATION_MULTIPLIER=1.0
