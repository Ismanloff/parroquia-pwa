!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Artillery load testing results
tests/load/.env.load-test
tests/load/report.json
tests/load/*.json
load-test-report.html
report.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
*.env.local
*.env.production
*.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

